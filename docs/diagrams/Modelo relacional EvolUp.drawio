        <mxCell id="nota-check" parent="1" style="text;html=1;strokeColor=#b8860b;fillColor=#fffde7;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;fontColor=#333333;whiteSpace=wrap;strokeWidth=2;" value="&lt;b style=&quot;font-size:13px;&quot;&gt;Restricciones CHECK y UNIQUE compuesta&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;• USUARIO.email LIKE &apos;%@%.%&apos;&lt;br&gt;• OBJETIVO.estado IN (&apos;activo&apos;, &apos;completado&apos;, &apos;cancelado&apos;)&lt;br&gt;• OBJETIVO.fecha_objetivo &amp;gt; fecha_inicio&lt;br&gt;• HABITO.frecuencia IN (&apos;diario&apos;, &apos;semanal&apos;)&lt;br&gt;• REGISTRO: UNIQUE (id_habito_fk, fecha)&lt;/font&gt;" vertex="1">
          <mxGeometry height="175" width="510" x="590" y="360" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
